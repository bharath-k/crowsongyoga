---
import { site } from '../lib/content';
const { visit } = site;
---

<section id="visit" class="bg-sand-100/60 py-20 sm:py-24">
  <div class="mx-auto max-w-6xl px-5">
    <h2 class="text-3xl font-semibold text-charcoal sm:text-4xl">{visit.heading}</h2>
    <p class="mt-4 max-w-2xl text-lg text-muted">{visit.intro}</p>

    <div class="mt-10 grid gap-8 lg:grid-cols-2">
      <div>
        <h3 class="font-display text-xl text-charcoal">Where to find us</h3>
        <address class="mt-3 not-italic leading-relaxed text-charcoal">
          {visit.address}
        </address>
        <p class="mt-3 text-sm text-muted">{visit.directions}</p>

        <div class="mt-6 space-y-2">
          {
            visit.email && (
              <p class="text-sm">
                <span class="font-medium text-charcoal">Email: </span>
                <a href={`mailto:${visit.email}`} class="text-clay hover:text-clay-dark">
                  {visit.email}
                </a>
              </p>
            )
          }
          {
            visit.phone && (
              <p class="text-sm">
                <span class="font-medium text-charcoal">Phone: </span>
                <a href={`tel:${visit.phone.replace(/\s+/g, '')}`} class="text-clay hover:text-clay-dark">
                  {visit.phone}
                </a>
              </p>
            )
          }
        </div>
      </div>

      <div class="overflow-hidden rounded-2xl border border-sand-200 shadow-sm">
        <iframe
          title="Map to the shala"
          src={visit.map_embed}
          class="h-72 w-full lg:h-full"
          style="border:0;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
    </div>
  </div>
</section>
