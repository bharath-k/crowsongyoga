---
import { site } from '../lib/content';
const { rates, payment } = site;
---

<section id="rates" class="mx-auto max-w-6xl px-5 py-20 sm:py-24">
  <h2 class="text-3xl font-semibold text-charcoal sm:text-4xl">{rates.heading}</h2>
  <p class="mt-4 max-w-2xl text-lg text-muted">{rates.intro}</p>

  <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {
      rates.items.map((item) => (
        <div class="flex flex-col rounded-2xl border border-sand-200 bg-sand-50 p-8">
          <span class="font-display text-xl text-charcoal">{item.name}</span>
          <span class="mt-3 text-4xl font-semibold text-clay-dark">{item.price}</span>
          {item.note && <span class="mt-3 text-sm text-muted">{item.note}</span>}
          <div class="mt-auto pt-6">
            {item.checkout_url ? (
              <a
                href={item.checkout_url}
                target="_blank"
                rel="noopener"
                class="inline-block rounded-full bg-clay px-6 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-clay-dark"
              >
                {item.cta_label ?? 'Get started'}
              </a>
            ) : (
              <span
                class="inline-block rounded-full border border-sand-300 px-6 py-2.5 text-sm font-semibold text-muted"
                title="Add a checkout link in site.yaml to enable this button"
              >
                {item.cta_label ?? 'Get started'} - coming soon
              </span>
            )}
          </div>
        </div>
      ))
    }
  </div>

  <p class="mt-6 text-sm italic text-muted">{rates.footnote}</p>

  <div class="mt-8 rounded-2xl border border-sand-200 bg-sand-100/60 p-6 sm:p-8">
    <h3 class="font-display text-xl text-charcoal">{payment.heading}</h3>
    <p class="mt-3 leading-relaxed text-muted">{payment.body}</p>
    <p class="mt-3 text-sm italic text-muted">{payment.note}</p>
  </div>
</section>
