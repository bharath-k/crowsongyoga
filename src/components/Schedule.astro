---
import { site } from '../lib/content';
import { getVancouverDateStr } from '../lib/schedule';
import TodayBanner from './TodayBanner.astro';

const { schedule } = site;

const weekdays = [
  { name: 'Monday', wd: 1, session: schedule.days.monday },
  { name: 'Tuesday', wd: 2, session: schedule.days.tuesday },
  { name: 'Wednesday', wd: 3, session: schedule.days.wednesday },
  { name: 'Thursday', wd: 4, session: schedule.days.thursday },
  { name: 'Friday', wd: 5, session: schedule.days.friday },
];

function formatDate(dateStr: string): string {
  return new Date(`${dateStr}T00:00:00Z`).toLocaleDateString('en-CA', {
    timeZone: 'UTC',
    weekday: 'short',
    month: 'short',
    day: 'numeric',
  });
}

const today = getVancouverDateStr();
const upcomingThemes = schedule.saturday_themes.filter((t) => t.date >= today).slice(0, 4);
const upcomingMoonDays = schedule.moon_rest_days.filter((d) => d >= today).slice(0, 6);
---

<section id="schedule" class="bg-sand-100/60 py-20 sm:py-24">
  <div class="mx-auto max-w-6xl px-5">
    <h2 class="text-3xl font-semibold text-charcoal sm:text-4xl">{schedule.heading}</h2>
    <p class="mt-4 max-w-3xl text-lg text-muted">{schedule.intro}</p>

    <div class="mt-8">
      <TodayBanner />
    </div>

    <div
      id="weekday-grid"
      data-moon-days={JSON.stringify(schedule.moon_rest_days)}
      class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-5"
    >
      {
        weekdays.map((d) => (
          <div
            data-weekday={d.wd}
            class="flex flex-col rounded-xl border border-sand-200 bg-sand-50 p-5"
          >
            <span class="font-display text-xl text-charcoal">{d.name}</span>
            <span class="day-time mt-2 text-sm font-semibold text-clay-dark">{d.session.time}</span>
            <span class="day-type mt-2 text-sm leading-relaxed text-muted">{d.session.type}</span>
            {d.name === 'Friday' && (
              <span class="alternates-note mt-3 text-xs italic text-sage">Alternates weekly</span>
            )}
          </div>
        ))
      }
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-2">
      <!-- Saturdays -->
      <div class="rounded-xl border border-sand-200 bg-sand-50 p-6">
        <h3 class="font-display text-xl text-charcoal">Themed Saturdays</h3>
        <p class="mt-2 text-sm text-muted">{schedule.saturday_note}</p>
        {
          upcomingThemes.length > 0 ? (
            <ul class="mt-4 space-y-2">
              {upcomingThemes.map((t) => (
                <li class="flex flex-col border-l-2 border-sage pl-3">
                  <span class="text-sm font-semibold text-charcoal">{formatDate(t.date)}</span>
                  <span class="text-sm text-muted">{t.theme}</span>
                </li>
              ))}
            </ul>
          ) : (
            <p class="mt-4 text-sm italic text-muted">No themed Saturdays scheduled yet.</p>
          )
        }
      </div>

      <!-- Moon rest days -->
      <div class="rounded-xl border border-sand-200 bg-sand-50 p-6">
        <h3 class="font-display text-xl text-charcoal">Full &amp; New Moon rest days</h3>
        <p class="mt-2 text-sm text-muted">{schedule.moon_note}</p>
        {
          upcomingMoonDays.length > 0 && (
            <ul class="mt-4 flex flex-wrap gap-2">
              {upcomingMoonDays.map((d) => (
                <li class="rounded-full bg-sand-200 px-3 py-1 text-xs font-medium text-charcoal">
                  {formatDate(d)}
                </li>
              ))}
            </ul>
          )
        }
        <a
          href={schedule.moon_days_link}
          target="_blank"
          rel="noopener"
          class="mt-4 inline-block text-sm font-medium text-clay hover:text-clay-dark"
        >
          See all moon days &rarr;
        </a>
      </div>
    </div>

    <p class="mt-8 text-sm italic text-muted">{schedule.closed_note}</p>
  </div>
</section>

<script>
  import { getVancouverDateStr, nextWeekdayDate } from '../lib/schedule';

  const grid = document.getElementById('weekday-grid');
  if (grid) {
    const moonDays: string[] = JSON.parse(grid.dataset.moonDays || '[]');
    const today = getVancouverDateStr(new Date());
    grid.querySelectorAll<HTMLElement>('[data-weekday]').forEach((card) => {
      const date = nextWeekdayDate(today, Number(card.dataset.weekday));
      if (!moonDays.includes(date)) return;
      card.style.borderColor = 'var(--color-clay)';
      card.style.backgroundColor = 'var(--color-sand-100)';
      const typeEl = card.querySelector<HTMLElement>('.day-type');
      if (typeEl) {
        typeEl.textContent = 'Moon day - take rest';
        typeEl.style.color = 'var(--color-clay-dark)';
        typeEl.style.fontWeight = '600';
      }
      const timeEl = card.querySelector<HTMLElement>('.day-time');
      if (timeEl) timeEl.textContent = 'No class';
      const altEl = card.querySelector<HTMLElement>('.alternates-note');
      if (altEl) altEl.style.display = 'none';
    });
  }
</script>
