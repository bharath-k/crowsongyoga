---
import { site } from '../lib/content';
const { media } = site;
const videos = media.videos ?? [];
const hasVideo = videos.length > 0;
---

<section class="bg-sand-100/60 py-20 sm:py-24">
  <div class="mx-auto max-w-5xl px-5 text-center">
    <h2 class="text-3xl font-semibold text-charcoal sm:text-4xl">{media.intro_video_heading}</h2>

    {
      hasVideo ? (
        <div class={`mt-8 grid gap-6 ${videos.length > 1 ? 'sm:grid-cols-2' : ''}`}>
          {videos.map((v) => (
            <figure class="overflow-hidden rounded-2xl border border-sand-200 shadow-sm">
              <video class="h-full w-full" controls preload="none" playsinline poster={v.poster}>
                <source src={v.src} type="video/mp4" />
                Your browser does not support embedded video.
              </video>
              {v.caption && <figcaption class="bg-white px-4 py-3 text-sm text-muted">{v.caption}</figcaption>}
            </figure>
          ))}
        </div>
      ) : (
        <Fragment>
          <div class="mt-8 overflow-hidden rounded-2xl border border-sand-200 shadow-sm">
            <img
              src="/images/video-poster-placeholder.svg"
              alt="Video placeholder"
              class="h-full w-full object-cover"
              loading="lazy"
            />
          </div>
          <p class="mt-4 text-sm italic text-muted">{media.intro_video_caption}</p>
        </Fragment>
      )
    }
  </div>
</section>
